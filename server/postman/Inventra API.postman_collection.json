    {
      "name": "SETUP",
      "item": [
        {
          "name": "SETUP - Create category for later tests",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "packages": {},
                "requests": {},
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"category created\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const categoryId = json._id || json.id || json.category?._id || json.category?.id;",
                  "",
                  "pm.test(\"category id saved\", function () {",
                  "  pm.expect(categoryId).to.exist;",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"generalCategory\", categoryId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"Postman Test Category {{$timestamp}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["categories"]
            }
          },
          "response": []
        },
        {
          "name": "SETUP - Create product for later tests",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "packages": {},
                "requests": {},
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test(\"product created\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const productId = json._id || json.id || json.product?._id || json.product?.id;",
                  "",
                  "pm.test(\"product id saved\", function () {",
                  "  pm.expect(productId).to.exist;",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"testProductId\", productId);",
                  "pm.collectionVariables.set(\"duplicateSkuOrBarcode\", json.skuOrBarcode || json.sku_or_barcode);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"testProductCreatedWithPost {{$timestamp}}\",\r\n  \"categoryId\": \"{{generalCategory}}\",\r\n  \"skuOrBarcode\": \"noSkuOrBarcode-{{$timestamp}}\",\r\n  \"unit\": \"kg\",\r\n  \"price\": 100,\r\n  \"reorderLevel\": 5\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          },
          "response": []
        }
      ]
    },
